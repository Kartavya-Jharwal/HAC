<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>HAC – Hult AI Collective</title>
    <meta name="description" content="The AI buildspace at Hult London. Ship multi-agent systems, RAG pipelines, and agentic workflows. No CS degree required.">
    <link rel="canonical" href="https://hultaicollective.com/">

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="HAC – Hult AI Collective">
    <meta property="og:description" content="Build. Automate. Ship. The AI common room for business students who want to make things.">
    <meta property="og:url" content="https://hultaicollective.com/">
    <meta property="og:image" content="https://hultaicollective.com/assets/images/og-image.jpg">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="HAC – Hult AI Collective">
    <meta name="twitter:description" content="The AI buildspace for business students who want to make things.">

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='4' fill='%23E54B2A'/%3E%3Ctext x='16' y='22' font-family='Georgia,serif' font-size='14' font-weight='bold' fill='white' text-anchor='middle'%3EH%3C/text%3E%3C/svg%3E">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400;1,8..60,600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="assets/css/hac-landing.css">

    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Hult AI Collective",
        "alternateName": "HAC",
        "url": "https://hultaicollective.com",
        "description": "Technical buildspace at Hult London where business students learn multi-agent systems, RAG, and agentic workflows.",
        "foundingDate": "2025",
        "parentOrganization": {
            "@type": "CollegeOrUniversity",
            "name": "Hult International Business School"
        }
    }
    </script>
</head>
<body>

    <!-- Liquid Cursor -->
    <div class="cursor" aria-hidden="true"></div>

    <!-- Dashed Grid Background -->
    <div class="grid-bg" aria-hidden="true"></div>

    <a href="#main" class="skip-link">Skip to main content</a>

    <!-- Floating Navigation -->
    <nav class="nav" role="navigation">
        <div class="nav-pill">
            <a href="#" class="nav-logo">
                <img src="assets/images/HAC_Wordmark.svg" alt="HAC" class="nav-logo__svg">
            </a>
            <div class="nav-links">
                <a href="#laws">Laws</a>
                <a href="#build">Build</a>
                <a href="#how">How It Works</a>
                <a href="investors/">Investors</a>
                <a href="HAC-Access/" class="nav-cta nav-cta--access">HAC-Access</a>
                <a href="#join" class="nav-cta">Join</a>
            </div>
            <button class="nav-toggle" aria-label="Menu" aria-expanded="false">
                <span></span>
                <span></span>
            </button>
        </div>
    </nav>

    <main id="main">

        <!-- ============ HERO ============ -->
        <section class="hero">
            <div class="hero-content">
                <img src="assets/images/HAC_Lockup.svg" alt="Hult AI Collective" class="hero-lockup">
                <h1 class="hero-title">Where business students<br><em>learn to ship.</em></h1>
                <div class="hero-ctas">
                    <a href="#join" class="btn btn-primary">Join the Collective</a>
                    <a href="HAC-Access/" class="btn btn-primary btn-access">HAC-Access &rarr;</a>
                    <a href="#laws" class="btn btn-text">Read the Laws &darr;</a>
                </div>
            </div>
        </section>

        <!-- ============ QUOTE ============ -->
        <section class="section section--quote">
            <div class="container container--narrow">
                <blockquote class="hero-quote">
                    <p>"Think Gryffindor common room meets Y Combinator office hours."</p>
                </blockquote>
                <p class="hero-desc">HAC is a technical buildspace where you ship multi-agent systems, RAG pipelines, and automation workflows — no CS degree, no lectures, no fluff.</p>
            </div>
        </section>

        <!-- ============ THREE LAWS ============ -->
        <section class="section section--laws" id="laws">
            <div class="container container--narrow">
                <p class="section-eyebrow">The Three Laws</p>
                <h2 class="section-title">Three laws govern this house.</h2>
                <p class="laws-intro">You'll hear them at every session.</p>
                <ol class="laws">
                    <li class="law">
                        <span class="law-number">I</span>
                        <div class="law-body">
                            <h3>First Law</h3>
                            <p>A member may not defer judgment to a machine, or through laziness, allow their decision-making to atrophy.</p>
                        </div>
                    </li>
                    <li class="law">
                        <span class="law-number">II</span>
                        <div class="law-body">
                            <h3>Second Law</h3>
                            <p>A member may employ AI as a tool — except where such use would violate the First Law.</p>
                        </div>
                    </li>
                    <li class="law">
                        <span class="law-number">III</span>
                        <div class="law-body">
                            <h3>Third Law</h3>
                            <p>A member must pursue fun, human connection, and meaningful work — except where this conflicts with the First or Second Law.</p>
                        </div>
                    </li>
                </ol>
            </div>
        </section>

        <!-- ============ WHAT YOU BUILD ============ -->
        <section class="section section--cream" id="build">
            <div class="container">
                <p class="section-eyebrow">Practical Tools, Not Theory</p>
                <h2 class="section-title">What you'll build</h2>
                <div class="build-grid">
                    <div class="build-item">
                        <span class="build-number">01</span>
                        <h3>Multi-Agent Systems</h3>
                        <p>Build AI teams that research, write, and coordinate without you micromanaging every prompt.</p>
                    </div>
                    <div class="build-item">
                        <span class="build-number">02</span>
                        <h3>Automation Workflows</h3>
                        <p>Turn 3-hour manual tasks into 10-minute scripts. Import data, generate reports, scrape insights.</p>
                    </div>
                    <div class="build-item">
                        <span class="build-number">03</span>
                        <h3>RAG Applications</h3>
                        <p>Create AI that knows your business context — course materials, company docs, proprietary research.</p>
                    </div>
                </div>
                <p class="build-footer">Portfolio-ready projects. Ship in weeks, not months.</p>
            </div>
        </section>

        <!-- ============ HOW IT WORKS ============ -->
        <section class="section" id="how">
            <div class="container container--narrow">
                <h2 class="section-title">How it works</h2>
                <ol class="steps">
                    <li class="step">
                        <div class="step-marker">1</div>
                        <div class="step-body">
                            <h3>Monthly Workshops</h3>
                            <p>2-hour hands-on build sessions. You ship a working prototype before you leave.</p>
                        </div>
                    </li>
                    <li class="step">
                        <div class="step-marker">2</div>
                        <div class="step-body">
                            <h3>Co-Working Evenings</h3>
                            <p>Bi-weekly drop-in. Work on your project, debug with peers. Bring your laptop, stay as long as you want.</p>
                        </div>
                    </li>
                    <li class="step">
                        <div class="step-marker">3</div>
                        <div class="step-body">
                            <h3>Common Room Culture</h3>
                            <p>Music. Snacks. Space designed for focus and experimentation. HAC is where you go to build.</p>
                        </div>
                    </li>
                    <li class="step">
                        <div class="step-marker">4</div>
                        <div class="step-body">
                            <h3>Trial Board Model</h3>
                            <p>Join as a trial contributor. Ship tasks for 2 weeks. Earn your board role through execution.</p>
                        </div>
                    </li>
                </ol>
            </div>
        </section>

        <!-- ============ WHO ============ -->
        <section class="section section--cream" id="who">
            <div class="container container--narrow">
                <h2 class="section-title">Who this is for</h2>
                <div class="who-content">
                    <div class="who-col">
                        <p class="who-label who-label--yes">You'll thrive here if…</p>
                        <ul class="who-list">
                            <li>You want to automate workflows, not just understand AI theory</li>
                            <li>You're comfortable learning by building (and breaking things)</li>
                            <li>You need portfolio-ready work for internships, startups, or jobs</li>
                            <li>You're exploring devrel, AI implementation, or builder roles</li>
                        </ul>
                    </div>
                    <div class="who-col">
                        <p class="who-label who-label--no">Probably not for you if…</p>
                        <ul class="who-list who-list--muted">
                            <li>You want passive learning (lectures, panels, decks)</li>
                            <li>You're collecting club badges for your CV</li>
                            <li>You need hand-holding through every line of code</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <!-- ============ COMBINED JOIN + FOOTER ============ -->
    <footer class="site-footer" id="join" role="contentinfo">

        <!-- Join Band -->
        <div class="footer-join">
            <div class="container container--narrow">
                <h2 class="footer-join__title">Join the Collective</h2>
                <p class="footer-join__lead">Board applications are currently closed. Connect with us below.</p>
                <div class="footer-join__ctas">
                    <a href="https://chat.whatsapp.com/your-invite-link" class="btn btn-primary btn-large js-whatsapp" target="_blank" rel="noopener">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                        Join on WhatsApp
                    </a>
                    <a href="HAC-Access/" class="btn btn-outline btn-large">
                        HAC-Access Dashboard &rarr;
                    </a>
                    <a href="https://linkedin.com/company/hultaicollective" class="btn btn-outline btn-large" target="_blank" rel="noopener">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                        Follow on LinkedIn
                    </a>
                    <a href="https://instagram.com/hultaicollective" class="btn btn-outline btn-large" target="_blank" rel="noopener">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                        Follow on Instagram
                    </a>
                </div>
            </div>
        </div>

        <!-- Footer Navigation -->
        <div class="footer-nav">
            <div class="container">
                <div class="footer-grid">

                    <!-- Brand -->
                    <div class="footer-col footer-col--brand">
                        <img src="assets/images/HAC_Wordmark.svg" alt="HAC" class="footer-logo__svg">
                        <p class="footer-tagline">Hult AI Collective<br>Hult International Business School, London</p>
                    </div>

                    <!-- Navigate -->
                    <div class="footer-col">
                        <h4 class="footer-col__title">Navigate</h4>
                        <ul>
                            <li><a href="#laws">The Three Laws</a></li>

                            <li><a href="https://chat.whatsapp.com/your-invite-link" target="_blank" rel="noopener" class="js-whatsapp">WhatsApp</a></li>
                            <li><a href="https://linkedin.com/company/hultaicollective" target="_blank" rel="noopener">LinkedIn</a></li>
                            <li><a href="https://instagram.com/hultaicollective" target="_blank" rel="noopener">Instagram</a></li>
                            <li><a href="mailto:hultaicollective@gmail.com">Email</a></li>
                        </ul>
                    </div>

                    <!-- Contact -->
                    <div class="footer-col">
                        <h4 class="footer-col__title">Contact</h4>
                        <ul>
                            <li><strong>Kartavya Jharwal</strong>, President</li>
                            <li><a href="https://kartavya.tech" target="_blank" rel="noopener">kartavya.tech</a></li>
                            <li><a href="mailto:kjharwal@student.hult.edu">kjharwal@student.hult.edu</a></li>
                        </ul>
                    </div>

                </div>
            </div>
        </div>

        <!-- Legal Bar -->
        <div class="footer-legal">
            <div class="container">
                <div class="footer-legal__inner">
                    <p>&copy; <span class="js-year">2026</span> Hult AI Collective. All rights reserved.</p>
